# Django secret key (generate a strong random string)
DJANGO_SECRET_KEY=change-me-to-a-random-secret

# MongoDB is NOT used — Django uses SQLite by default.
# If you want Postgres, set DATABASE_URL here.

# JWT secret (must match the frontend cookie expectations)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# Debug mode (set to False in production)
DEBUG=True
